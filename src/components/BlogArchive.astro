---
import { CATEGORY_KEYS, CATEGORY_META } from "../config/categories";
import { PAGE_SIZE, type PostEntry } from "../lib/posts";
import BlogCard from "./BlogCard.astro";
import Pagination from "./Pagination.astro";

interface Props {
    posts: PostEntry[];
    currentPage: number;
    lastPage: number;
    previous?: string;
    next?: string;
}

const { posts, currentPage, lastPage, previous, next } = Astro.props;
const tagCounts = new Map<string, number>();

for (const post of posts) {
    for (const tag of new Set(post.data.tags)) {
        tagCounts.set(tag, (tagCounts.get(tag) ?? 0) + 1);
    }
}

const tags = [...tagCounts]
    .sort(([leftTag, leftCount], [rightTag, rightCount]) =>
        rightCount - leftCount || leftTag.localeCompare(rightTag, "zh-CN"),
    );
---

<blog-archive data-current-page={currentPage} data-last-page={lastPage} data-total={posts.length}>
    <form class="rounded-xl border border-zinc-200 bg-white p-4 sm:p-5 dark:border-zinc-800 dark:bg-zinc-900" data-filter-form>
        <fieldset>
            <legend class="text-sm font-semibold text-zinc-900 dark:text-zinc-100">按分类筛选</legend>
            <div class="mt-3 flex flex-wrap gap-2">
                <label>
                    <input class="peer sr-only" type="radio" name="category" value="" checked />
                    <span class="inline-flex cursor-pointer rounded-full border border-zinc-300 px-3 py-1.5 text-sm text-zinc-600 transition peer-checked:border-zinc-900 peer-checked:bg-zinc-900 peer-checked:text-white peer-focus-visible:outline-2 peer-focus-visible:outline-offset-2 peer-focus-visible:outline-orange-500 dark:border-zinc-700 dark:text-zinc-300 dark:peer-checked:border-zinc-100 dark:peer-checked:bg-zinc-100 dark:peer-checked:text-zinc-900">
                        全部
                    </span>
                </label>
                {
                    CATEGORY_KEYS.map((key) => (
                        <label>
                            <input class="peer sr-only" type="radio" name="category" value={key} />
                            <span class="inline-flex cursor-pointer rounded-full border border-zinc-300 px-3 py-1.5 text-sm text-zinc-600 transition peer-checked:border-orange-600 peer-checked:bg-orange-50 peer-checked:text-orange-700 peer-focus-visible:outline-2 peer-focus-visible:outline-offset-2 peer-focus-visible:outline-orange-500 dark:border-zinc-700 dark:text-zinc-300 dark:peer-checked:border-orange-400 dark:peer-checked:bg-orange-400/10 dark:peer-checked:text-orange-300">
                                {CATEGORY_META[key].name}
                            </span>
                        </label>
                    ))
                }
            </div>
        </fieldset>

        <div class="mt-4 flex flex-col gap-3 border-t border-zinc-200 pt-4 sm:flex-row sm:items-end dark:border-zinc-800">
            <label class="min-w-0 flex-1">
                <span class="mb-2 block text-sm font-semibold text-zinc-900 dark:text-zinc-100">按标签筛选</span>
                <select
                    name="tag"
                    data-tag-select
                    class="w-full rounded-lg border border-zinc-300 bg-white px-3 py-2.5 text-sm text-zinc-900 outline-none transition focus:border-orange-500 focus:ring-2 focus:ring-orange-500/20 dark:border-zinc-700 dark:bg-zinc-950 dark:text-zinc-100"
                >
                    <option value="">全部标签</option>
                    {tags.map(([tag, count]) => <option value={tag}>{tag}（{count}）</option>)}
                </select>
            </label>
            <button
                type="button"
                data-reset-filter
                class="min-h-10 rounded-lg border border-zinc-300 px-4 text-sm font-medium text-zinc-600 transition hover:border-orange-300 hover:text-orange-600 disabled:cursor-not-allowed disabled:opacity-40 dark:border-zinc-700 dark:text-zinc-300 dark:hover:border-orange-700 dark:hover:text-orange-400"
                disabled
            >
                清除筛选
            </button>
        </div>
        <p class="mt-3 text-sm text-zinc-500 dark:text-zinc-400" data-filter-status aria-live="polite">
            共 {posts.length} 篇 · 第 {currentPage}/{lastPage} 页
        </p>
        <noscript>
            <p class="mt-2 text-sm text-zinc-500 dark:text-zinc-400">筛选功能需要启用 JavaScript。</p>
        </noscript>
    </form>

    <div class="mt-6 space-y-4" data-post-list>
        {
            posts.map((post, index) => {
                const postPage = Math.floor(index / PAGE_SIZE) + 1;
                return (
                    <div
                        data-post-card
                        data-page={postPage}
                        data-categories={post.data.categories.join(" ")}
                        data-tags={JSON.stringify(post.data.tags)}
                        hidden={postPage !== currentPage}
                    >
                        <BlogCard post={post} />
                    </div>
                );
            })
        }
    </div>

    <div data-pagination>
        <Pagination
            currentPage={currentPage}
            lastPage={lastPage}
            previous={previous}
            next={next}
        />
    </div>
</blog-archive>

<script>
    class BlogArchiveElement extends HTMLElement {
        private controller?: AbortController;

        connectedCallback() {
            this.controller?.abort();
            this.controller = new AbortController();
            const { signal } = this.controller;

            const form = this.querySelector<HTMLFormElement>("[data-filter-form]");
            const tagSelect = this.querySelector<HTMLSelectElement>("[data-tag-select]");
            const resetButton = this.querySelector<HTMLButtonElement>("[data-reset-filter]");
            const status = this.querySelector<HTMLElement>("[data-filter-status]");
            const pagination = this.querySelector<HTMLElement>("[data-pagination]");
            const cards = [...this.querySelectorAll<HTMLElement>("[data-post-card]")];

            if (!form || !tagSelect || !resetButton || !status || !pagination) return;

            const currentPage = Number(this.dataset.currentPage ?? "1");
            const lastPage = Number(this.dataset.lastPage ?? "1");
            const total = Number(this.dataset.total ?? cards.length);
            const validCategories = new Set([
                "",
                ...[...form.querySelectorAll<HTMLInputElement>('input[name="category"]')].map((input) => input.value),
            ]);
            const validTags = new Set([...tagSelect.options].map((option) => option.value));

            const readUrlState = () => {
                const url = new URL(window.location.href);
                const categoryParam = url.searchParams.get("category") ?? "";
                const tagParam = url.searchParams.get("tag") ?? "";
                return {
                    category: validCategories.has(categoryParam) ? categoryParam : "",
                    tag: validTags.has(tagParam) ? tagParam : "",
                };
            };

            const setControls = (category: string, tag: string) => {
                const categoryInput = form.querySelector<HTMLInputElement>(`input[name="category"][value="${CSS.escape(category)}"]`);
                if (categoryInput) categoryInput.checked = true;
                tagSelect.value = tag;
            };

            const filteredUrl = (category: string, tag: string) => {
                const nextUrl = new URL(window.location.href);
                if (category || tag) nextUrl.pathname = "/blog";
                if (category) nextUrl.searchParams.set("category", category);
                else nextUrl.searchParams.delete("category");
                if (tag) nextUrl.searchParams.set("tag", tag);
                else nextUrl.searchParams.delete("tag");
                return nextUrl;
            };

            const renderFilters = (category: string, tag: string) => {
                const filtering = Boolean(category || tag);
                let count = 0;

                for (const card of cards) {
                    const categories = new Set((card.dataset.categories ?? "").split(" ").filter(Boolean));
                    const tags = new Set<string>(JSON.parse(card.dataset.tags ?? "[]"));
                    const matches = (!category || categories.has(category)) && (!tag || tags.has(tag));
                    const onCurrentPage = Number(card.dataset.page) === currentPage;
                    card.hidden = filtering ? !matches : !onCurrentPage;
                    if (matches) count += 1;
                }

                pagination.hidden = filtering;
                resetButton.disabled = !filtering;
                status.textContent = filtering
                    ? `找到 ${count} 篇文章`
                    : `共 ${total} 篇 · 第 ${currentPage}/${lastPage} 页`;
            };

            const applyControlState = (updateHistory: boolean) => {
                const category = new FormData(form).get("category")?.toString() ?? "";
                const tag = tagSelect.value;
                const nextUrl = filteredUrl(category, tag);

                if (updateHistory && (category || tag) && currentPage > 1) {
                    window.location.assign(nextUrl.toString());
                    return;
                }

                renderFilters(category, tag);
                if (updateHistory && nextUrl.href !== window.location.href) {
                    window.history.pushState(window.history.state, "", nextUrl);
                }
            };

            const syncFromUrl = () => {
                const { category, tag } = readUrlState();
                if ((category || tag) && currentPage > 1) {
                    window.location.replace(filteredUrl(category, tag).toString());
                    return;
                }
                setControls(category, tag);
                renderFilters(category, tag);
            };

            form.addEventListener("change", () => applyControlState(true), { signal });
            resetButton.addEventListener("click", () => {
                const allCategories = form.querySelector<HTMLInputElement>('input[name="category"][value=""]');
                if (allCategories) allCategories.checked = true;
                tagSelect.value = "";
                applyControlState(true);
            }, { signal });
            window.addEventListener("popstate", syncFromUrl, { signal });

            syncFromUrl();
        }

        disconnectedCallback() {
            this.controller?.abort();
        }
    }

    if (!customElements.get("blog-archive")) {
        customElements.define("blog-archive", BlogArchiveElement);
    }
</script>
