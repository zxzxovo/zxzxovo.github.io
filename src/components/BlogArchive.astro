---
import { CATEGORY_KEYS, CATEGORY_META } from "../config/categories";
import { PAGE_SIZE, type PostEntry } from "../lib/posts";
import BlogCard from "./BlogCard.astro";
import Pagination from "./Pagination.astro";

interface Props {
    posts: PostEntry[];
    currentPage: number;
    lastPage: number;
    previous?: string;
    next?: string;
}

const { posts, currentPage, lastPage, previous, next } = Astro.props;
const tagCounts = new Map<string, number>();

for (const post of posts) {
    for (const tag of new Set(post.data.tags)) {
        tagCounts.set(tag, (tagCounts.get(tag) ?? 0) + 1);
    }
}

const tags = [...tagCounts]
    .sort(([leftTag, leftCount], [rightTag, rightCount]) =>
        rightCount - leftCount || leftTag.localeCompare(rightTag, "zh-CN"),
    );
---

<blog-archive data-current-page={currentPage} data-last-page={lastPage} data-total={posts.length} data-pagefind-ignore>
    <form class="rounded-xl border border-zinc-200 bg-white p-4 sm:p-5 dark:border-zinc-800 dark:bg-zinc-900" data-filter-form>
        <div class="grid gap-4 sm:grid-cols-[minmax(0,1fr)_minmax(13rem,0.8fr)] sm:items-end">
            <fieldset>
                <legend class="text-sm font-semibold text-zinc-900 dark:text-zinc-100">按分类筛选</legend>
                <div class="mt-3 flex flex-wrap gap-2">
                    <label>
                        <input class="peer sr-only" type="radio" name="category" value="" checked />
                        <span class="inline-flex cursor-pointer rounded-full border border-zinc-300 px-3 py-1.5 text-sm text-zinc-600 transition peer-checked:border-zinc-900 peer-checked:bg-zinc-900 peer-checked:text-white peer-focus-visible:outline-2 peer-focus-visible:outline-offset-2 peer-focus-visible:outline-orange-500 dark:border-zinc-700 dark:text-zinc-300 dark:peer-checked:border-zinc-100 dark:peer-checked:bg-zinc-100 dark:peer-checked:text-zinc-900">
                            全部
                        </span>
                    </label>
                    {
                        CATEGORY_KEYS.map((key) => (
                            <label>
                                <input class="peer sr-only" type="radio" name="category" value={key} />
                                <span class="inline-flex cursor-pointer rounded-full border border-zinc-300 px-3 py-1.5 text-sm text-zinc-600 transition peer-checked:border-orange-600 peer-checked:bg-orange-50 peer-checked:text-orange-700 peer-focus-visible:outline-2 peer-focus-visible:outline-offset-2 peer-focus-visible:outline-orange-500 dark:border-zinc-700 dark:text-zinc-300 dark:peer-checked:border-orange-400 dark:peer-checked:bg-orange-400/10 dark:peer-checked:text-orange-300">
                                    {CATEGORY_META[key].name}
                                </span>
                            </label>
                        ))
                    }
                </div>
            </fieldset>

            <label class="min-w-0">
                <span class="mb-2 block text-sm font-semibold text-zinc-900 dark:text-zinc-100">按标签筛选</span>
                <select
                    name="tag"
                    data-tag-select
                    class="w-full rounded-lg border border-zinc-300 bg-white px-3 py-2.5 text-sm text-zinc-900 outline-none transition focus:border-orange-500 focus:ring-2 focus:ring-orange-500/20 dark:border-zinc-700 dark:bg-zinc-950 dark:text-zinc-100"
                >
                    <option value="">全部标签</option>
                    {tags.map(([tag, count]) => <option value={tag}>{tag}（{count}）</option>)}
                </select>
            </label>
        </div>

        <div class="mt-4 flex flex-wrap items-center justify-between gap-3 border-t border-zinc-200 pt-4 dark:border-zinc-800">
            <button
                type="button"
                data-reset-filter
                class="min-h-10 rounded-lg border border-zinc-300 px-4 text-sm font-medium text-zinc-600 transition hover:border-orange-300 hover:text-orange-600 disabled:cursor-not-allowed disabled:opacity-40 dark:border-zinc-700 dark:text-zinc-300 dark:hover:border-orange-700 dark:hover:text-orange-400"
                disabled
            >
                清除筛选
            </button>
            <p class="text-sm text-zinc-500 dark:text-zinc-400" data-filter-status aria-live="polite">
                共 {posts.length} 篇 · 第 {currentPage}/{lastPage} 页
            </p>
        </div>
        <noscript>
            <p class="mt-2 text-sm text-zinc-500 dark:text-zinc-400">筛选功能需要启用 JavaScript。</p>
        </noscript>
    </form>

    <div class="mt-6 space-y-4" data-post-list>
        {
            posts.map((post, index) => {
                const postPage = Math.floor(index / PAGE_SIZE) + 1;
                return (
                    <div
                        data-post-card
                        data-page={postPage}
                        data-categories={post.data.categories.join(" ")}
                        data-tags={JSON.stringify(post.data.tags)}
                        hidden={postPage !== currentPage}
                    >
                        <BlogCard post={post} />
                    </div>
                );
            })
        }
    </div>

    <div data-pagination>
        <Pagination
            currentPage={currentPage}
            lastPage={lastPage}
            previous={previous}
            next={next}
        />
    </div>
</blog-archive>
