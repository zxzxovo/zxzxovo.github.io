---
import type { PostEntry } from "../lib/posts";
import { getPostHref } from "../lib/posts";
import BlogInfoBar from "./BlogInfoBar.astro";
import PostCover from "./PostCover.astro";
import TagSmall from "./TagSmall.astro";

interface Props {
    post: PostEntry;
}

const { post } = Astro.props;
const { title, date, description, tags, cover, categories } = post.data;
const href = getPostHref(post);
---

<article class="group overflow-hidden rounded-[0.625rem] border border-zinc-200 bg-white transition-[border-color,transform] duration-200 hover:-translate-y-0.5 hover:border-orange-300 dark:border-zinc-800 dark:bg-zinc-900 dark:hover:border-orange-700">
    <div class="flex flex-col sm:min-h-44 sm:flex-row">
        {
            cover ? (
                <a
                    class="block aspect-[16/9] w-full overflow-hidden bg-zinc-100 sm:aspect-[4/3] sm:w-60 sm:shrink-0 dark:bg-zinc-800"
                    href={href}
                    aria-label={`阅读《${title}》`}
                    tabindex="-1"
                >
                    <PostCover
                        src={cover}
                        alt=""
                        widths={[320, 480, 720]}
                        sizes="(max-width: 639px) calc(100vw - 2rem), 15rem"
                        class="h-full w-full object-cover transition-transform duration-200 group-hover:scale-[1.025]"
                    />
                </a>
            ) : (
                <a
                    class="flex aspect-[16/9] w-full items-center justify-center bg-zinc-100 px-8 text-center sm:aspect-[4/3] sm:w-60 sm:shrink-0 dark:bg-zinc-800"
                    href={href}
                    aria-label={`阅读《${title}》`}
                    tabindex="-1"
                >
                    <span class="text-2xl font-bold tracking-[-0.03em] text-zinc-400 dark:text-zinc-500">
                        {title}
                    </span>
                </a>
            )
        }

        <div class="flex min-w-0 flex-1 flex-col p-4 sm:p-5">
            <BlogInfoBar date={date} categories={categories} />

            <h2 class="mt-2 text-lg font-bold leading-snug tracking-[-0.02em] text-zinc-950 dark:text-zinc-50">
                <a
                    href={href}
                    class="transition-colors duration-200 group-hover:text-orange-600 dark:group-hover:text-orange-400"
                >
                    {title}
                </a>
            </h2>

            <p class="mt-1.5 line-clamp-2 text-sm leading-5 text-zinc-600 dark:text-zinc-400">
                {description}
            </p>

            <div class="mt-auto pt-3">
                <TagSmall tags={tags} limit={3} />
            </div>
        </div>
    </div>
</article>
