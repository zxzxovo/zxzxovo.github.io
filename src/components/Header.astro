---
import { Icon } from "astro-icon/components";
import { Image } from "astro:assets";
import logoImage from "../assets/images/identity/logo.webp";

interface Props {
    underlined?: string;
}

const { underlined } = Astro.props;
const destinations = [
    { name: "首页", url: "/" as const },
    { name: "博客", url: "/blog" as const },
    { name: "分类", url: "/categories" as const },
    { name: "工具", url: "/tools" as const },
    { name: "友链", url: "/friends" as const },
    { name: "关于", url: "/about" as const },
];
---

<header class="sticky top-0 z-40 border-b border-zinc-200 bg-zinc-50 dark:border-zinc-800 dark:bg-zinc-950">
    <div class="mx-auto flex h-[4.5rem] max-w-6xl items-center gap-5 px-4 sm:px-6 lg:px-8">
        <a
            href="/"
            class="flex shrink-0 items-center gap-2.5 text-lg font-bold tracking-[-0.025em] text-zinc-950 transition-colors duration-200 hover:text-orange-600 dark:text-zinc-50 dark:hover:text-orange-400"
            aria-label="芷夏，返回首页"
        >
            <Image
                src={logoImage}
                alt=""
                width="32"
                height="32"
                densities={[2]}
                format="webp"
                quality={82}
                priority
                class="size-8 rounded-full border border-zinc-200 object-cover dark:border-zinc-700"
            />
            <span>芷夏</span>
        </a>

        <nav
            class="site-nav-scroll ml-auto min-w-0 flex-1 overflow-x-auto"
            aria-label="主导航"
            data-site-nav
        >
            <ul class="ml-auto flex w-max items-center gap-1 sm:gap-2">
                {
                    destinations.map((destination) => {
                        const active = underlined === destination.url;
                        return (
                            <li>
                                <a
                                    href={destination.url}
                                    aria-current={active ? "page" : undefined}
                                    class:list={[
                                        "inline-flex min-h-10 items-center rounded-md px-2.5 text-sm font-medium transition-colors duration-200 sm:px-3",
                                        active
                                            ? "bg-orange-50 text-orange-600 dark:bg-orange-950/40 dark:text-orange-400"
                                            : "text-zinc-600 hover:bg-zinc-100 hover:text-zinc-950 dark:text-zinc-400 dark:hover:bg-zinc-900 dark:hover:text-zinc-50",
                                    ]}
                                >
                                    {destination.name}
                                </a>
                            </li>
                        );
                    })
                }
            </ul>
        </nav>

        <a
            href="/search"
            aria-label="全站搜索"
            title="全站搜索"
            aria-current={underlined === "/search" ? "page" : undefined}
            class:list={[
                "inline-flex size-10 shrink-0 items-center justify-center rounded-md transition-colors duration-200",
                underlined === "/search"
                    ? "bg-orange-50 text-orange-600 dark:bg-orange-950/40 dark:text-orange-400"
                    : "text-zinc-600 hover:bg-zinc-100 hover:text-zinc-950 dark:text-zinc-400 dark:hover:bg-zinc-900 dark:hover:text-zinc-50",
            ]}
        >
            <Icon name="mdi:magnify" size="1.25rem" />
        </a>

        <div class="h-5 w-px bg-zinc-200 dark:bg-zinc-800" aria-hidden="true"></div>
        <button
            type="button"
            data-theme-toggle
            aria-label="切换为深色主题"
            title="切换为深色主题"
            class="inline-flex size-10 shrink-0 items-center justify-center rounded-md text-zinc-600 transition-colors duration-200 hover:bg-zinc-100 hover:text-zinc-950 dark:text-zinc-400 dark:hover:bg-zinc-900 dark:hover:text-zinc-50"
        >
            <span data-theme-icon="light" aria-hidden="true"><Icon name="mdi:moon-waning-crescent" size="1.25rem" /></span>
            <span data-theme-icon="dark" aria-hidden="true"><Icon name="mdi:white-balance-sunny" size="1.25rem" /></span>
        </button>
    </div>
</header>

<script>
    const revealCurrentNavigation = () => {
        const navigation = document.querySelector<HTMLElement>("[data-site-nav]");
        const current = navigation?.querySelector<HTMLElement>('[aria-current="page"]');

        if (!navigation || !current || navigation.scrollWidth <= navigation.clientWidth) return;

        navigation.scrollTo({
            left: Math.max(
                0,
                current.offsetLeft - (navigation.clientWidth - current.clientWidth) / 2,
            ),
            behavior: "auto",
        });
    };

    revealCurrentNavigation();
    document.addEventListener("astro:page-load", revealCurrentNavigation);
</script>
