---
import type { MarkdownHeading } from "astro";

interface Props {
    headings: MarkdownHeading[];
}

const { headings } = Astro.props;
---

<details data-toc-root class="mb-8 rounded-[0.625rem] border border-zinc-200 bg-white p-4 lg:hidden dark:border-zinc-800 dark:bg-zinc-900">
    <summary class="cursor-pointer text-sm font-semibold text-zinc-900 dark:text-zinc-100">
        本文目录（{headings.length}）
    </summary>
    <ol class="mt-3 space-y-1.5 border-l border-zinc-200 pl-3 dark:border-zinc-800">
        {
            headings.map((heading) => (
                <li class:list={[heading.depth === 3 && "pl-3"]}>
                    <a
                        data-toc-link
                        href={`#${heading.slug}`}
                        class="relative block py-0.5 text-sm leading-5 text-zinc-500 transition-colors duration-200 before:absolute before:inset-y-0 before:-left-[13px] before:w-0.5 before:rounded-full before:bg-transparent before:transition-colors before:duration-200 hover:text-orange-600 data-[current]:font-semibold data-[current]:text-orange-600 data-[current]:before:bg-orange-500 dark:text-zinc-400 dark:hover:text-orange-400 dark:data-[current]:text-orange-400 dark:data-[current]:before:bg-orange-400"
                    >
                        {heading.text}
                    </a>
                </li>
            ))
        }
    </ol>
</details>

<aside data-toc-root class="sticky top-24 hidden max-h-[calc(100vh-7rem)] self-start overflow-y-auto pr-2 lg:col-start-2 lg:row-start-1 lg:block" aria-label="本文目录">
    <p class="text-sm font-semibold text-zinc-900 dark:text-zinc-100">本文目录</p>
    <ol class="mt-3 space-y-1.5 border-l border-zinc-200 pl-3 dark:border-zinc-800">
        {
            headings.map((heading) => (
                <li class:list={[heading.depth === 3 && "pl-3"]}>
                    <a
                        data-toc-link
                        href={`#${heading.slug}`}
                        class="relative block py-0.5 text-sm leading-5 text-zinc-500 transition-colors duration-200 before:absolute before:inset-y-0 before:-left-[13px] before:w-0.5 before:rounded-full before:bg-transparent before:transition-colors before:duration-200 hover:text-orange-600 data-[current]:font-semibold data-[current]:text-orange-600 data-[current]:before:bg-orange-500 dark:text-zinc-400 dark:hover:text-orange-400 dark:data-[current]:text-orange-400 dark:data-[current]:before:bg-orange-400"
                    >
                        {heading.text}
                    </a>
                </li>
            ))
        }
    </ol>
</aside>
