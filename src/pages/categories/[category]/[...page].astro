---
import type { GetStaticPaths, Page } from "astro";
import BlogCard from "../../../components/BlogCard.astro";
import Pagination from "../../../components/Pagination.astro";
import { CATEGORY_KEYS, CATEGORY_META, type CategoryKey } from "../../../config/categories";
import App from "../../../layouts/App.astro";
import { getPublishedPosts, PAGE_SIZE, type PostEntry } from "../../../lib/posts";

export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
    const posts = await getPublishedPosts();

    return CATEGORY_KEYS.flatMap((category) =>
        paginate(
            posts.filter((post) => post.data.categories.includes(category)),
            {
                pageSize: PAGE_SIZE,
                params: { category },
                props: { category },
            },
        ),
    );
};

interface Props {
    category: CategoryKey;
    page: Page<PostEntry>;
}

const { category, page } = Astro.props;
const meta = CATEGORY_META[category];
const pageTitle = page.currentPage > 1
    ? `${meta.name} · 第 ${page.currentPage} 页`
    : meta.name;
---

<App title={pageTitle} description={`${meta.description}。浏览“${meta.name}”分类下的文章。`} underlined="/categories">
    <div class="mx-auto max-w-4xl">
        <header class="mb-10">
            <a
                href="/categories"
                class="text-sm font-medium text-zinc-500 transition-colors duration-200 hover:text-orange-600 dark:text-zinc-400 dark:hover:text-orange-400"
            >← 返回全部分类</a>
            <div class="mt-5 flex flex-wrap items-end justify-between gap-3">
                <div>
                    <h1 class="text-3xl font-bold tracking-[-0.035em] text-zinc-950 sm:text-4xl dark:text-zinc-50">{meta.name}</h1>
                    <p class="mt-3 leading-7 text-zinc-600 dark:text-zinc-400">{meta.description}</p>
                </div>
                <span class="text-sm text-zinc-500 dark:text-zinc-400">共 {page.total} 篇</span>
            </div>
        </header>

        <div class="space-y-4" data-pagefind-ignore>
            {page.data.map((post) => <BlogCard post={post} />)}
        </div>

        <Pagination
            currentPage={page.currentPage}
            lastPage={page.lastPage}
            previous={page.url.prev}
            next={page.url.next}
        />
    </div>
</App>
