---
import { CATEGORY_KEYS, CATEGORY_META } from "../../config/categories";
import App from "../../layouts/App.astro";
import { getPublishedPosts } from "../../lib/posts";

const posts = await getPublishedPosts();
---

<App title="分类" description="按主题浏览芷夏的文章。" underlined="/categories">
    <div class="mx-auto max-w-4xl">
        <header class="mb-10">
            <p class="text-sm font-semibold tracking-[0.14em] text-orange-600 uppercase dark:text-orange-400">Categories</p>
            <h1 class="mt-2 text-3xl font-bold tracking-[-0.035em] text-zinc-950 sm:text-4xl dark:text-zinc-50">文章分类</h1>
            <p class="mt-3 leading-7 text-zinc-600 dark:text-zinc-400">四个方向，收拢散落在时间里的记录。</p>
        </header>

        <div class="grid gap-4 sm:grid-cols-2">
            {
                CATEGORY_KEYS.map((key) => {
                    const category = CATEGORY_META[key];
                    const count = posts.filter((post) => post.data.categories.includes(key)).length;
                    return (
                        <a
                            href={category.href}
                            class="group flex min-h-44 flex-col rounded-[0.625rem] border border-zinc-200 bg-white p-6 transition-[border-color,transform] duration-200 hover:-translate-y-0.5 hover:border-orange-300 dark:border-zinc-800 dark:bg-zinc-900 dark:hover:border-orange-700"
                        >
                            <div class="flex items-start justify-between gap-4">
                                <h2 class="text-xl font-bold tracking-[-0.02em] text-zinc-950 transition-colors duration-200 group-hover:text-orange-600 dark:text-zinc-50 dark:group-hover:text-orange-400">
                                    {category.name}
                                </h2>
                                <span class="rounded-full bg-zinc-100 px-2.5 py-1 text-xs tabular-nums text-zinc-500 dark:bg-zinc-800 dark:text-zinc-400">
                                    {count} 篇
                                </span>
                            </div>
                            <p class="mt-3 text-sm leading-6 text-zinc-500 dark:text-zinc-400">{category.description}</p>
                            <span class="mt-auto pt-5 text-sm font-medium text-orange-600 dark:text-orange-400">浏览文章 →</span>
                        </a>
                    );
                })
            }
        </div>
    </div>
</App>
