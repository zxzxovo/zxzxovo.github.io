---
import type { GetStaticPaths, Page } from "astro";
import BlogArchive from "../../components/BlogArchive.astro";
import App from "../../layouts/App.astro";
import { getPublishedPosts, PAGE_SIZE, type PostEntry } from "../../lib/posts";

export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
    const posts = await getPublishedPosts();
    return paginate(posts, { pageSize: PAGE_SIZE });
};

interface Props {
    page: Page<PostEntry>;
}

const { page } = Astro.props;
const posts = await getPublishedPosts();
const pageTitle = page.currentPage > 1 ? `博客 · 第 ${page.currentPage} 页` : "博客";
---

<App title={pageTitle} description="芷夏的全部文章，记录编程、生活与思考。" underlined="/blog">
    <div class="mx-auto max-w-4xl">
        <header class="mb-10">
            <p class="text-sm font-semibold tracking-[0.14em] text-orange-600 uppercase dark:text-orange-400">Archive</p>
            <h1 class="mt-2 text-3xl font-bold tracking-[-0.035em] text-zinc-950 sm:text-4xl dark:text-zinc-50">博客</h1>
            <p class="mt-3 max-w-2xl leading-7 text-zinc-600 dark:text-zinc-400">
                写下学到的事，也保存那些不愿忘记的片刻。
            </p>
        </header>

        <BlogArchive
            posts={posts}
            currentPage={page.currentPage}
            lastPage={page.lastPage}
            previous={page.url.prev}
            next={page.url.next}
        />
    </div>
</App>
