---
import { render } from "astro:content";
import { Icon } from "astro-icon/components";
import ProjectCard from "../../components/projects/ProjectCard.astro";
import { tools } from "../../data/tool-catalog";
import App from "../../layouts/App.astro";
import { getPublishedProjects } from "../../lib/projects";

const projects = await getPublishedProjects();
const renderedProjects = await Promise.all(
    projects.map(async (project) => {
        const { Content } = await render(project);
        return { project, Content };
    }),
);
---

<App
    title="工具"
    description="几个简单、透明、只在浏览器里运行的小工具，以及偶尔完成的小项目。"
    underlined="/tools"
>
    <div class="mx-auto max-w-5xl">
        <header class="max-w-2xl">
            <p
                class="mb-4 text-xs font-semibold tracking-[0.2em] text-orange-600 uppercase dark:text-orange-400"
            >
                Tools
            </p>
            <h1
                class="text-4xl font-bold tracking-tight text-zinc-950 sm:text-5xl dark:text-zinc-50"
            >
                轻巧的小工具
            </h1>
            <p class="mt-5 text-base leading-7 text-zinc-600 dark:text-zinc-300">
                没有账号、没有上传，也没有藏在背后的服务。需要的时候打开，用完就走。
            </p>
        </header>

        <ul class="mt-10 grid gap-4 md:grid-cols-3">
            {
                tools.map((tool, index) => (
                    <li>
                        <a
                            href={tool.href}
                            class="group flex h-full min-h-64 flex-col rounded-xl border border-zinc-200 bg-white p-5 transition hover:-translate-y-1 hover:border-orange-300 hover:shadow-md hover:shadow-zinc-200/50 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-orange-500 dark:border-zinc-800 dark:bg-zinc-900 dark:hover:border-orange-700 dark:hover:shadow-none"
                        >
                            <div class="flex items-start justify-between gap-3">
                                <span class="flex h-11 w-11 items-center justify-center rounded-lg bg-orange-50 text-orange-600 dark:bg-orange-950/50 dark:text-orange-400">
                                    <Icon name={tool.icon} size="1.4rem" />
                                </span>
                                <span class="rounded-full border border-zinc-200 px-2.5 py-1 text-xs text-zinc-500 dark:border-zinc-700 dark:text-zinc-400">
                                    {tool.badge}
                                </span>
                            </div>
                            <p class="mt-8 text-xs font-medium text-zinc-400">0{index + 1}</p>
                            <h2 class="mt-2 text-lg font-semibold text-zinc-900 group-hover:text-orange-600 dark:text-zinc-100 dark:group-hover:text-orange-400">
                                {tool.title}
                            </h2>
                            <p class="mt-2 text-sm leading-6 text-zinc-500 dark:text-zinc-400">
                                {tool.description}
                            </p>
                            <span class="mt-auto inline-flex items-center gap-1.5 pt-6 text-sm font-medium text-orange-600 dark:text-orange-400">
                                打开工具
                                <Icon
                                    name="mdi:arrow-right"
                                    size="1rem"
                                    class="transition-transform group-hover:translate-x-1"
                                />
                            </span>
                        </a>
                    </li>
                ))
            }
        </ul>

        <p class="mt-8 text-center text-xs text-zinc-400 dark:text-zinc-500">
            所有交互数据仅保留在当前页面，刷新后即会清空。
        </p>

        {
            renderedProjects.length > 0 && (
                <section
                    class="mt-20 border-t border-zinc-200 pt-14 dark:border-zinc-800"
                    aria-labelledby="projects-heading"
                >
                    <header class="max-w-2xl">
                        <p class="mb-3 text-xs font-semibold tracking-[0.2em] text-orange-600 uppercase dark:text-orange-400">
                            Projects
                        </p>
                        <h2
                            id="projects-heading"
                            class="text-2xl font-bold tracking-tight text-zinc-950 sm:text-3xl dark:text-zinc-50"
                        >
                            藏在角落里的项目
                        </h2>
                        <p class="mt-4 text-sm leading-7 text-zinc-600 dark:text-zinc-300">
                            偶尔也会做些不太像工具的小东西，它们会慢慢出现在这里。
                        </p>
                    </header>

                    <ul class="mt-8 grid gap-4 md:grid-cols-2">
                        {renderedProjects.map(({ project, Content }) => (
                            <li>
                                <ProjectCard project={project}>
                                    <Content />
                                </ProjectCard>
                            </li>
                        ))}
                    </ul>
                </section>
            )
        }
    </div>
</App>
