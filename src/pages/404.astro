---
import App from "../layouts/App.astro";
---

<App title="页面未找到" description="你访问的页面不存在或已经移动。" noindex>
  <section
    class="mx-auto grid min-h-[min(34rem,65vh)] max-w-2xl place-content-center justify-items-start gap-3"
    aria-labelledby="not-found-title"
  >
    <p class="text-xs font-semibold tracking-[0.14em] text-orange-600 uppercase dark:text-orange-400">404</p>
    <h1 id="not-found-title" class="text-4xl font-bold tracking-[-0.04em] text-zinc-950 sm:text-6xl dark:text-zinc-50">
      这里没有你要找的页面
    </h1>
    <p class="leading-8 text-zinc-500 dark:text-zinc-400">它可能已经移动，也可能从来没有存在过。</p>
    <div class="mt-3 flex flex-wrap gap-3">
      <a class="btn-primary" href="/">返回首页</a>
      <a class="btn-secondary" href="/blog">浏览文章</a>
    </div>
  </section>
</App>
