---
import SearchExplorer from "../components/SearchExplorer";
import App from "../layouts/App.astro";
---

<App
    title="搜索"
    description="搜索芷夏博客中的文章、页面、工具与项目。"
    underlined="/search"
    noindex
    pagefindIgnore
>
    <div class="mx-auto max-w-3xl">
        <header class="mb-8">
            <p class="text-sm font-semibold tracking-[0.14em] text-orange-600 uppercase dark:text-orange-400">Search</p>
            <h1 class="mt-2 text-3xl font-bold tracking-[-0.035em] text-zinc-950 sm:text-4xl dark:text-zinc-50">全站搜索</h1>
            <p class="mt-3 max-w-2xl leading-7 text-zinc-600 dark:text-zinc-400">
                标题、摘要、标签和文章正文都可以被找到。
            </p>
        </header>

        <SearchExplorer client:load />
    </div>
</App>
