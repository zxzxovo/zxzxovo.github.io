---
export interface Props {
    title?: string;
    description?: string;
}
import "../styles/global.css";

const {
    title = "芷夏的个人网站",
    description = "记录生活，美食，编程，灵感。",
} = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="description" content={description} />
        <title>{title}</title>
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    </head>
    <body>
        <slot name="header" />
        <main>
            <slot />
        </main>
        <slot name="footer" />
    </body>
</html>
