---
import { Icon } from "astro-icon/components";
import { friends } from "../data/friends";
import App from "../layouts/App.astro";
---

<App
    title="友链"
    description="芷夏的朋友们，以及交换友情链接的简短说明。"
    underlined="/friends"
>
    <div class="mx-auto max-w-4xl">
        <header class="max-w-2xl">
            <p
                class="mb-4 text-xs font-semibold tracking-[0.2em] text-orange-600 uppercase dark:text-orange-400"
            >
                Friends
            </p>
            <h1
                class="text-4xl font-bold tracking-tight text-zinc-950 sm:text-5xl dark:text-zinc-50"
            >
                互联网上的邻居
            </h1>
            <p class="mt-5 text-base leading-7 text-zinc-600 dark:text-zinc-300">
                每一个长期写作的独立站点，都让互联网多了一点人的温度。这里会收集我常去拜访的朋友。
            </p>
        </header>

        {
            friends.length > 0 ? (
                <ul class="mt-10 grid gap-4 sm:grid-cols-2">
                    {friends.map((friend) => (
                        <li>
                            <a
                                href={friend.url}
                                target="_blank"
                                rel="noreferrer"
                                class="group flex h-full items-start gap-4 rounded-xl border border-zinc-200 bg-white p-5 transition hover:-translate-y-0.5 hover:border-orange-300 hover:shadow-sm focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-orange-500 dark:border-zinc-800 dark:bg-zinc-900 dark:hover:border-orange-700"
                            >
                                {friend.avatar ? (
                                    <img
                                        src={friend.avatar}
                                        alt=""
                                        loading="lazy"
                                        class="h-12 w-12 shrink-0 rounded-lg object-cover"
                                    />
                                ) : (
                                    <span class="flex h-12 w-12 shrink-0 items-center justify-center rounded-lg bg-orange-50 text-lg font-semibold text-orange-600 dark:bg-orange-950/50 dark:text-orange-400">
                                        {friend.name.slice(0, 1)}
                                    </span>
                                )}
                                <span class="min-w-0">
                                    <span class="flex items-center gap-2 font-semibold text-zinc-900 group-hover:text-orange-600 dark:text-zinc-100 dark:group-hover:text-orange-400">
                                        {friend.name}
                                        <Icon name="mdi:arrow-top-right" size="1rem" />
                                    </span>
                                    <span class="mt-1.5 block text-sm leading-6 text-zinc-500 dark:text-zinc-400">
                                        {friend.description}
                                    </span>
                                </span>
                            </a>
                        </li>
                    ))}
                </ul>
            ) : (
                <section class="mt-10 rounded-xl border border-dashed border-zinc-300 bg-zinc-100/50 px-6 py-14 text-center dark:border-zinc-700 dark:bg-zinc-900/40">
                    <span class="mx-auto flex h-11 w-11 items-center justify-center rounded-full bg-white text-zinc-500 dark:bg-zinc-900 dark:text-zinc-400">
                        <Icon name="mdi:link-variant" size="1.35rem" />
                    </span>
                    <h2 class="mt-4 font-semibold text-zinc-900 dark:text-zinc-100">
                        友链正在慢慢整理
                    </h2>
                    <p class="mx-auto mt-2 max-w-md text-sm leading-6 text-zinc-500 dark:text-zinc-400">
                        这里暂时还是一张空桌子。如果你也在持续维护自己的独立站点，欢迎来信介绍你和你的作品。
                    </p>
                </section>
            )
        }

        <section
            class="mt-8 flex flex-col gap-5 rounded-xl border border-zinc-200 bg-white p-6 sm:flex-row sm:items-center sm:justify-between dark:border-zinc-800 dark:bg-zinc-900"
            aria-labelledby="friend-exchange"
        >
            <div>
                <h2
                    id="friend-exchange"
                    class="font-semibold text-zinc-900 dark:text-zinc-100"
                >
                    交换友链
                </h2>
                <p class="mt-2 max-w-xl text-sm leading-6 text-zinc-500 dark:text-zinc-400">
                    来信时请附上站点名称、地址和一句简短介绍。内容以原创为主、可以正常访问即可。
                </p>
            </div>
            <a
                href="mailto:zhixiaovo@gmail.com?subject=%E4%BA%A4%E6%8D%A2%E5%8F%8B%E9%93%BE"
                class="inline-flex min-h-10 shrink-0 items-center justify-center gap-2 rounded-lg bg-orange-600 px-4 text-sm font-semibold text-white transition hover:bg-orange-700 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-orange-500 dark:bg-orange-500 dark:hover:bg-orange-400"
            >
                <Icon name="mdi:email-outline" size="1.1rem" />
                发送邮件
            </a>
        </section>
    </div>
</App>
