---
import type { MarkdownHeading } from "astro";

interface Props {
    headings: MarkdownHeading[];
}

const { headings } = Astro.props;
---

<details data-toc-root class="mb-8 rounded-[0.625rem] border border-zinc-200 bg-white p-4 lg:hidden dark:border-zinc-800 dark:bg-zinc-900">
    <summary class="cursor-pointer text-sm font-semibold text-zinc-900 dark:text-zinc-100">
        本文目录
    </summary>
    <ol class="mt-3 space-y-1.5 border-l border-zinc-200 pl-3 dark:border-zinc-800">
        {
            headings.map((heading) => (
                <li class:list={[heading.depth === 3 && "pl-3"]}>
                    <a
                        data-toc-link
                        href={`#${heading.slug}`}
                        class="block py-0.5 text-sm leading-5 text-zinc-500 transition-colors duration-200 hover:text-orange-600 data-[current]:font-medium data-[current]:text-orange-600 dark:text-zinc-400 dark:hover:text-orange-400 dark:data-[current]:text-orange-400"
                    >
                        {heading.text}
                    </a>
                </li>
            ))
        }
    </ol>
</details>

<aside data-toc-root class="sticky top-24 hidden self-start lg:col-start-2 lg:row-start-1 lg:block" aria-label="本文目录">
    <p class="text-sm font-semibold text-zinc-900 dark:text-zinc-100">本文目录</p>
    <ol class="mt-3 space-y-1.5 border-l border-zinc-200 pl-3 dark:border-zinc-800">
        {
            headings.map((heading) => (
                <li class:list={[heading.depth === 3 && "pl-3"]}>
                    <a
                        data-toc-link
                        href={`#${heading.slug}`}
                        class="block py-0.5 text-sm leading-5 text-zinc-500 transition-colors duration-200 hover:text-orange-600 data-[current]:font-medium data-[current]:text-orange-600 dark:text-zinc-400 dark:hover:text-orange-400 dark:data-[current]:text-orange-400"
                    >
                        {heading.text}
                    </a>
                </li>
            ))
        }
    </ol>
</aside>

<script>
    let disposeToc: (() => void) | undefined;

    function setupToc() {
        disposeToc?.();

        const links = Array.from(
            document.querySelectorAll<HTMLAnchorElement>("[data-toc-link]"),
        );
        if (links.length === 0) return;

        const headings = links
            .map((link) => {
                const id = decodeURIComponent(link.hash.slice(1));
                return document.getElementById(id);
            })
            .filter((heading): heading is HTMLElement => Boolean(heading));

        let frame = 0;
        const update = () => {
            frame = 0;
            let current = headings[0];
            for (const heading of headings) {
                if (heading.getBoundingClientRect().top <= 150) current = heading;
                else break;
            }

            for (const link of links) {
                const active = decodeURIComponent(link.hash.slice(1)) === current?.id;
                link.toggleAttribute("data-current", active);
                if (active) link.setAttribute("aria-current", "location");
                else link.removeAttribute("aria-current");
            }
        };

        const onScroll = () => {
            if (!frame) frame = requestAnimationFrame(update);
        };

        window.addEventListener("scroll", onScroll, { passive: true });
        update();

        disposeToc = () => {
            window.removeEventListener("scroll", onScroll);
            if (frame) cancelAnimationFrame(frame);
            disposeToc = undefined;
        };
    }

    setupToc();
    document.addEventListener("astro:page-load", setupToc);
    document.addEventListener("astro:before-swap", () => disposeToc?.());
</script>
