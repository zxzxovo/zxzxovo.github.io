---
import { CATEGORY_META, type CategoryKey } from "../config/categories";
import { formatPostDate, getCategoryHref } from "../lib/posts";

interface Props {
    date: Date;
    categories?: CategoryKey[];
}

const { date, categories = [] } = Astro.props;
---

<div class="flex flex-wrap items-center gap-x-2 gap-y-1 text-xs font-medium text-zinc-500 dark:text-zinc-400">
    <time datetime={date.toISOString()}>{formatPostDate(date)}</time>
    {
        categories.length > 0 && (
            <>
                <span class="text-zinc-300 dark:text-zinc-700" aria-hidden="true">/</span>
                <ul class="flex flex-wrap items-center gap-x-2 gap-y-1" aria-label="文章分类">
                    {categories.map((category) => (
                        <li>
                            <a
                                class="transition-colors duration-200 hover:text-orange-600 dark:hover:text-orange-400"
                                href={getCategoryHref(category)}
                            >
                                {CATEGORY_META[category].name}
                            </a>
                        </li>
                    ))}
                </ul>
            </>
        )
    }
</div>
