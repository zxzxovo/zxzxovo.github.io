---
import { Icon } from "astro-icon/components";

interface Props {
    tags: string[];
    limit?: number;
}

const { tags, limit } = Astro.props;
const visibleTags = typeof limit === "number" ? tags.slice(0, limit) : tags;
---

{
    visibleTags.length > 0 && (
        <ul class="flex w-full flex-wrap gap-1.5 overflow-hidden">
            {visibleTags.map((tag) => (
                <li>
                    <span
                        class="inline-flex max-w-full items-center gap-1 rounded-md border border-zinc-200 bg-zinc-50 px-2 py-0.5 text-xs leading-5 text-zinc-600 transition-colors hover:border-orange-300 hover:text-orange-600 dark:border-zinc-700 dark:bg-zinc-900 dark:text-zinc-300 dark:hover:border-orange-400 dark:hover:text-orange-300"
                    >
                        <Icon name="mdi:tag-outline" size="0.85rem" />
                        <span class="truncate">{tag}</span>
                    </span>
                </li>
            ))}
        </ul>
    )
}
