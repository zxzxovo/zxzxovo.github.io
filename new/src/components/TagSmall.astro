---
interface Props {
    tags: string[];
    limit?: number;
}

const { tags, limit } = Astro.props;
const visibleTags = typeof limit === "number" ? tags.slice(0, limit) : tags;
---

{
    visibleTags.length > 0 && (
        <ul class="flex flex-wrap gap-1.5" aria-label="文章标签">
            {visibleTags.map((tag) => (
                <li>
                    <span class="inline-flex rounded-md bg-zinc-100 px-2 py-1 text-xs leading-none text-zinc-600 dark:bg-zinc-800 dark:text-zinc-300">
                        #{tag}
                    </span>
                </li>
            ))}
        </ul>
    )
}
